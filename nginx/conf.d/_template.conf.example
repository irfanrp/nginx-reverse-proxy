# Template acuan buat nambah service baru.
# File .example TIDAK di-load nginx (bukan *.conf).
# Cara pakai: copy jadi <name>.conf, ganti <domain> + <upstream>, lalu reload:
#   docker exec nginx-proxy nginx -s reload
#
# Catatan cert: subdomain *.aboutdevops.my.id ke-cover cert wildcard di ssl.conf.
# Domain lain -> isu cert baru dulu, lalu ganti path di ssl.conf atau bikin snippet cert sendiri.

# HTTP -> HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name <domain>;
    include /etc/nginx/snippets/redirect-https.conf;
}

# HTTPS
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name <domain>;

    include /etc/nginx/snippets/ssl.conf;
    include /etc/nginx/snippets/security-headers.conf;

    location / {
        proxy_pass <upstream>;
        include /etc/nginx/snippets/proxy-params.conf;
    }
}
